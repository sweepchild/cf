<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="utf-8">
<title>MTR Analiz Raporu — TTNet vs TurkNet / Cloudflare Routing</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:       #ffffff;
  --bg2:      #f8f9fa;
  --bg3:      #f1f3f5;
  --border:   #dee2e6;
  --border2:  #e9ecef;
  --text:     #212529;
  --text2:    #495057;
  --text3:    #868e96;
  --tn:       #0f6e56;
  --tn-bg:    #f0fdf4;
  --tn-border:#a3cfbb;
  --tt:       #b91c1c;
  --tt-bg:    #fff5f5;
  --tt-border:#f5c2c7;
  --good:     #0f6e56;
  --warn:     #b45309;
  --bad:      #b91c1c;
  --mono:     'Courier New', Courier, monospace;
}
@media (prefers-color-scheme: dark) {
  :root {
    --bg:       #0d1117;
    --bg2:      #161b22;
    --bg3:      #1c2128;
    --border:   #30363d;
    --border2:  #21262d;
    --text:     #e6edf3;
    --text2:    #8b949e;
    --text3:    #6e7681;
    --tn:       #3fb950;
    --tn-bg:    #0d2016;
    --tn-border:#1f4a2e;
    --tt:       #f85149;
    --tt-bg:    #1f0d0d;
    --tt-border:#4a1a1a;
    --good:     #3fb950;
    --warn:     #d29922;
    --bad:      #f85149;
  }
}
body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 13px;
  line-height: 1.6;
  color: var(--text);
  background: var(--bg);
  padding: 2.5rem 2rem;
  max-width: 1200px;
}

/* ── Cover ── */
.cover { border-bottom: 2px solid var(--border); padding-bottom: 1.8rem; margin-bottom: 2rem; }
.cover h1 { font-size: 22px; font-weight: 700; margin-bottom: .4rem; }
.cover .meta { font-size: 12px; color: var(--text3); display: flex; flex-wrap: wrap; gap: 1.2rem; margin-top: .6rem; }
.cover .meta span::before { content: '▸ '; }

/* ── Section headings ── */
h2 { font-size: 14px; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
     color: var(--text3); border-bottom: 1px solid var(--border); padding-bottom: .4rem;
     margin: 2.8rem 0 1rem; }
h3 { font-size: 13px; font-weight: 700; margin: 2rem 0 .6rem; color: var(--text); }
h4 { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .07em;
     color: var(--text3); margin: 1.4rem 0 .5rem; }

/* ── Tags / badges ── */
.tag { display:inline-block; padding:2px 8px; border-radius:4px;
       font-size:10px; font-weight:700; letter-spacing:.03em; white-space:nowrap; }
.tag-g   { background:#d1fae5; color:#064e3b; }
.tag-r   { background:#fee2e2; color:#7f1d1d; }
.tag-y   { background:#fef9c3; color:#713f12; }
.tag-b   { background:#dbeafe; color:#1e3a8a; }
.tag-gray{ background:#f1f5f9; color:#475569; }
@media (prefers-color-scheme: dark) {
  .tag-g   { background:#064e3b; color:#6ee7b7; }
  .tag-r   { background:#450a0a; color:#fca5a5; }
  .tag-y   { background:#3d2a00; color:#fcd34d; }
  .tag-b   { background:#0c2340; color:#93c5fd; }
  .tag-gray{ background:#27272a; color:#a1a1aa; }
}

/* ── ISP colors ── */
.tn { color: var(--tn); font-weight: 700; }
.tt { color: var(--tt); font-weight: 700; }
.good { color: var(--good); font-weight: 600; }
.warn { color: var(--warn); font-weight: 600; }
.bad  { color: var(--bad);  font-weight: 600; }
.mono { font-family: var(--mono); font-size: 11px; color: var(--text2); }

/* ── Tables ── */
table { width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 1.6rem; }
th { background: var(--bg3); color: var(--text2); font-size: 10px; font-weight: 700;
     text-transform: uppercase; letter-spacing: .06em;
     padding: 7px 10px; border: 1px solid var(--border); white-space: nowrap; }
td { padding: 7px 10px; border: 1px solid var(--border2); vertical-align: middle; }
tr:nth-child(even) td { background: var(--bg2); }
.num { text-align: right; font-family: var(--mono); }
.section-sep td { background: var(--bg3); font-size: 10px; font-weight: 800;
                  text-transform: uppercase; letter-spacing: .08em; color: var(--text3);
                  padding: 5px 10px; border-color: var(--border); }

/* ── MTR hop tables ── */
.mtr-block { margin-bottom: 2.4rem; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
.mtr-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap;
              gap: .5rem; padding: .7rem 1rem; background: var(--bg3);
              border-bottom: 1px solid var(--border); }
.mtr-header .title { font-weight: 700; font-size: 13px; }
.mtr-header .meta  { font-size: 11px; color: var(--text3); font-family: var(--mono); }
.mtr-block table { margin: 0; border: none; }
.mtr-block th, .mtr-block td { border-left: none; border-right: none; }
.mtr-block th:first-child, .mtr-block td:first-child { border-left: none; }
.hop-bad  td { background: #fff5f5 !important; }
.hop-warn td { background: #fffbeb !important; }
.hop-ok   td { }
.hop-stealth td { background: #f8f9fa !important; color: #868e96; font-style: italic; }
@media (prefers-color-scheme: dark) {
  .hop-bad  td { background: #2d0d0d !important; }
  .hop-warn td { background: #2d2000 !important; }
  .hop-stealth td { background: #1a1a1a !important; }
}
.loss-bad  { color: var(--bad);  font-weight: 700; }
.loss-warn { color: var(--warn); font-weight: 700; }
.loss-ok   { color: var(--good); }

/* ── Grid for paired tests ── */
.pair { display: grid; grid-template-columns: 1fr 1fr; gap: 1.2rem; margin-bottom: 2rem; }
@media (max-width: 900px) { .pair { grid-template-columns: 1fr; } }

/* ── Verdict boxes ── */
.verdict { border-left: 4px solid; border-radius: 0 6px 6px 0;
           padding: 1rem 1.2rem; margin-bottom: 1rem; font-size: 12px; line-height: 1.8; }
.verdict-g { border-color: #16a34a; background: var(--tn-bg); color: var(--text); }
.verdict-r { border-color: #dc2626; background: var(--tt-bg); color: var(--text); }

/* ── Summary table color rows ── */
.row-tn td { border-left: 3px solid var(--tn); }
.row-tt td { border-left: 3px solid var(--tt); }

/* ── Legend ── */
.legend { display: flex; flex-wrap: wrap; gap: .8rem; margin-bottom: 1.6rem; align-items: center; font-size: 11px; color: var(--text2); }
.legend span { display: flex; align-items: center; gap: .3rem; }

/* ── Callout ── */
.callout { border: 1px solid var(--border); border-radius: 6px; padding: .9rem 1.1rem;
           background: var(--bg2); font-size: 12px; line-height: 1.7; margin-bottom: 1.4rem; }
.callout strong { display: block; margin-bottom: .3rem; font-size: 12px; }
</style>
</head>
<body>

<!-- ═══════════ COVER ═══════════ -->
<div class="cover">
  <h1>Cloudflare Routing Analizi — TTNet vs TurkNet</h1>
  <p style="color:var(--text2);margin-top:.4rem">MTR tabanlı ağ yolu ve paket kaybı incelemesi · Site adları maskeli</p>
  <div class="meta">
    <span>Test tarihi: 2026-03-25, 17:48–17:56</span>
    <span>Yöntem: <code>mtr --tcp --port=443 -rw -n</code></span>
    <span>ISP A: TurkNet AS12735</span>
    <span>ISP B: TTNet AS9121</span>
    <span>Site sayısı: 4 (A/B/C/D)</span>
    <span>Toplam test: 16 (4 site × 2 ISP × 2 tekrar)</span>
  </div>
</div>

<!-- ═══════════ LEGEND ═══════════ -->
<div class="legend">
  <span><span class="tag tag-g">IST</span> CF İstanbul PoP — lokal</span>
  <span><span class="tag tag-r">AMS/DUS</span> CF Avrupa PoP — yurt dışı</span>
  <span><span class="tag tag-y">ICMP rate limit</span> Sahte yüksek latency</span>
  <span><span class="tag tag-r">Congestion</span> Gerçek paket kaybı</span>
  <span><span class="tag tag-b">Stealth</span> ICMP TTL-exceeded yok</span>
  <span style="display:flex;align-items:center;gap:.3rem"><span style="width:12px;height:12px;background:#fee2e2;border:1px solid #f5c2c7;display:inline-block;border-radius:2px"></span> Sorunlu hop satırı</span>
  <span style="display:flex;align-items:center;gap:.3rem"><span style="width:12px;height:12px;background:#fef9c3;border:1px solid #fde68a;display:inline-block;border-radius:2px"></span> Uyarı hop satırı</span>
</div>

<!-- ═══════════════════════════════════════════════════════
     SITE A
════════════════════════════════════════════════════════ -->
<h2>Site A</h2>

<div class="pair">

  <!-- A / TurkNet / Test 1 -->
  <div class="mtr-block">
    <div class="mtr-header">
      <span class="title">Site A &nbsp;·&nbsp; <span class="tn">TurkNet</span> &nbsp;·&nbsp; Test 1</span>
      <span class="meta">2026-03-25 17:49:00 &nbsp;|&nbsp; <span class="tag tag-g">IST</span> &nbsp;|&nbsp; 9 hop</span>
    </div>
    <table>
      <thead><tr><th>Hop</th><th>IP</th><th class="num">Loss%</th><th class="num">Snt</th><th class="num">Last</th><th class="num">Avg</th><th class="num">Best</th><th class="num">Wrst</th><th class="num">StDev</th><th>Not</th></tr></thead>
      <tbody>
        <tr class="hop-ok"><td>1</td><td class="mono">192.168.5.1</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">49.5</td><td class="num">40.2</td><td class="num">8.7</td><td class="num">58.5</td><td class="num">15.3</td><td>Modem/router</td></tr>
        <tr class="hop-ok"><td>2</td><td class="mono">159.146.5.165</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">20.4</td><td class="num">38.4</td><td class="num">12.3</td><td class="num">118.1</td><td class="num">35.3</td><td>TurkNet edge</td></tr>
        <tr class="hop-ok"><td>3</td><td class="mono">10.50.39.209</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">9.6</td><td class="num">25.9</td><td class="num">9.1</td><td class="num">65.1</td><td class="num">21.6</td><td>TurkNet iç</td></tr>
        <tr class="hop-ok"><td>4</td><td class="mono">10.20.253.130</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">25.6</td><td class="num">29.5</td><td class="num">12.1</td><td class="num">68.5</td><td class="num">18.6</td><td>TurkNet iç</td></tr>
        <tr class="hop-ok"><td>5</td><td class="mono">10.20.253.125</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">31.9</td><td class="num">36.6</td><td class="num">10.6</td><td class="num">129.5</td><td class="num">36.1</td><td>TurkNet iç</td></tr>
        <tr class="hop-warn"><td>6</td><td class="mono">159.146.92.33</td><td class="num loss-warn">10.0%</td><td class="num">10</td><td class="num">4164</td><td class="num">2002</td><td class="num">10.2</td><td class="num">5162</td><td class="num">1734</td><td><span class="tag tag-y">ICMP rate limit</span> — hop 7 sağlıklı</td></tr>
        <tr class="hop-ok"><td>7</td><td class="mono">193.192.103.98</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">41.7</td><td class="num">59.3</td><td class="num">10.0</td><td class="num">115.9</td><td class="num">35.1</td><td>DE-CIX İstanbul</td></tr>
        <tr class="hop-ok"><td>8</td><td class="mono">159.146.3.6</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">70.5</td><td class="num">50.6</td><td class="num">10.3</td><td class="num">127.4</td><td class="num">36.0</td><td>TurkNet/DE-CIX</td></tr>
        <tr class="hop-ok"><td>9</td><td class="mono">172.67.73.167</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">40.6</td><td class="num">75.5</td><td class="num">10.8</td><td class="num">225.9</td><td class="num">65.8</td><td><strong class="good">CF IST edge ✓</strong></td></tr>
      </tbody>
    </table>
  </div>

  <!-- A / TurkNet / Test 2 -->
  <div class="mtr-block">
    <div class="mtr-header">
      <span class="title">Site A &nbsp;·&nbsp; <span class="tn">TurkNet</span> &nbsp;·&nbsp; Test 2</span>
      <span class="meta">2026-03-25 17:49:18 &nbsp;|&nbsp; <span class="tag tag-g">IST</span> &nbsp;|&nbsp; 9 hop</span>
    </div>
    <table>
      <thead><tr><th>Hop</th><th>IP</th><th class="num">Loss%</th><th class="num">Snt</th><th class="num">Last</th><th class="num">Avg</th><th class="num">Best</th><th class="num">Wrst</th><th class="num">StDev</th><th>Not</th></tr></thead>
      <tbody>
        <tr class="hop-ok"><td>1</td><td class="mono">192.168.5.1</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">54.0</td><td class="num">216.3</td><td class="num">9.2</td><td class="num">1308</td><td class="num">405.5</td><td>Modem/router</td></tr>
        <tr class="hop-ok"><td>2</td><td class="mono">159.146.5.165</td><td class="num loss-warn">10.0%</td><td class="num">10</td><td class="num">12.8</td><td class="num">153.0</td><td class="num">9.5</td><td class="num">1221</td><td class="num">400.7</td><td>TurkNet edge — jitter var</td></tr>
        <tr class="hop-ok"><td>3</td><td class="mono">10.50.39.209</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">13.9</td><td class="num">197.6</td><td class="num">9.9</td><td class="num">1169</td><td class="num">366.5</td><td>TurkNet iç</td></tr>
        <tr class="hop-ok"><td>4</td><td class="mono">10.20.253.130</td><td class="num loss-warn">10.0%</td><td class="num">10</td><td class="num">120.4</td><td class="num">191.5</td><td class="num">9.4</td><td class="num">1058</td><td class="num">345.1</td><td>TurkNet iç</td></tr>
        <tr class="hop-ok"><td>5</td><td class="mono">10.20.253.125</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">141.6</td><td class="num">199.9</td><td class="num">11.8</td><td class="num">1012</td><td class="num">297.2</td><td>TurkNet iç</td></tr>
        <tr class="hop-warn"><td>6</td><td class="mono">159.146.92.33</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">2135</td><td class="num">1727</td><td class="num">15.3</td><td class="num">4181</td><td class="num">1485</td><td><span class="tag tag-y">ICMP rate limit</span></td></tr>
        <tr class="hop-ok"><td>7</td><td class="mono">193.192.103.98</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">64.9</td><td class="num">110.5</td><td class="num">11.5</td><td class="num">790.4</td><td class="num">240.0</td><td>DE-CIX İstanbul</td></tr>
        <tr class="hop-ok"><td>8</td><td class="mono">159.146.3.6</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">32.0</td><td class="num">106.3</td><td class="num">11.7</td><td class="num">679.1</td><td class="num">207.0</td><td>TurkNet/DE-CIX</td></tr>
        <tr class="hop-ok"><td>9</td><td class="mono">172.67.73.167</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">76.7</td><td class="num">107.6</td><td class="num">11.7</td><td class="num">567.9</td><td class="num">166.9</td><td><strong class="good">CF IST edge ✓</strong></td></tr>
      </tbody>
    </table>
  </div>

  <!-- A / TTNet / Test 1 -->
  <div class="mtr-block">
    <div class="mtr-header">
      <span class="title">Site A &nbsp;·&nbsp; <span class="tt">TTNet</span> &nbsp;·&nbsp; Test 1</span>
      <span class="meta">2026-03-25 17:48:05 &nbsp;|&nbsp; <span class="tag tag-r">FRA/AMS</span> &nbsp;|&nbsp; 12 hop</span>
    </div>
    <table>
      <thead><tr><th>Hop</th><th>IP</th><th class="num">Loss%</th><th class="num">Snt</th><th class="num">Last</th><th class="num">Avg</th><th class="num">Best</th><th class="num">Wrst</th><th class="num">StDev</th><th>Not</th></tr></thead>
      <tbody>
        <tr class="hop-ok"><td>1</td><td class="mono">10.7.1.1</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">6.3</td><td class="num">10.7</td><td class="num">4.7</td><td class="num">27.2</td><td class="num">6.7</td><td>TTNet modem</td></tr>
        <tr class="hop-ok"><td>2</td><td class="mono">10.10.10.1</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">11.1</td><td class="num">18.8</td><td class="num">6.4</td><td class="num">84.2</td><td class="num">23.7</td><td>TTNet iç</td></tr>
        <tr class="hop-ok"><td>3</td><td class="mono">10.98.238.14</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">16.3</td><td class="num">21.7</td><td class="num">12.0</td><td class="num">36.2</td><td class="num">10.1</td><td>TTNet iç</td></tr>
        <tr class="hop-bad"><td>4</td><td class="mono">10.0.1.38</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">4166</td><td class="num">2513</td><td class="num">24.2</td><td class="num">5247</td><td class="num">1851</td><td><span class="tag tag-r">Congestion başlangıcı</span></td></tr>
        <tr class="hop-bad"><td>5</td><td class="mono">81.212.73.165</td><td class="num loss-bad">90.0%</td><td class="num">10</td><td class="num">1038</td><td class="num">1038</td><td class="num">1038</td><td class="num">1038</td><td class="num">0.0</td><td><span class="tag tag-r">Kritik kayıp</span></td></tr>
        <tr class="hop-bad"><td>6</td><td class="mono">212.156.108.128</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">4633</td><td class="num">4252</td><td class="num">3502</td><td class="num">5605</td><td class="num">853</td><td><span class="tag tag-r">TTNet omurga — kronik</span></td></tr>
        <tr class="hop-bad"><td>7</td><td class="mono">213.19.198.193 / 212.156.102.136</td><td class="num loss-bad">60.0%</td><td class="num">10</td><td class="num">7234</td><td class="num">7125</td><td class="num">7014</td><td class="num">7234</td><td class="num">90</td><td><span class="tag tag-r">ECMP karışımı</span></td></tr>
        <tr class="hop-bad"><td>8</td><td class="mono">212.156.102.136</td><td class="num loss-warn">10.0%</td><td class="num">10</td><td class="num">59.6</td><td class="num">1806</td><td class="num">58.3</td><td class="num">5199</td><td class="num">1984</td><td>TTNet çıkış</td></tr>
        <tr class="hop-ok"><td>9</td><td class="mono">213.19.198.193 / 213.248.75.222</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">77.3</td><td class="num">79.5</td><td class="num">63.1</td><td class="num">162.0</td><td class="num">30.0</td><td>Telia Carrier</td></tr>
        <tr class="hop-ok"><td>10</td><td class="mono">213.19.194.150 / 213.200.127.34</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">78.8</td><td class="num">284.2</td><td class="num">64.1</td><td class="num">2158</td><td class="num">659</td><td>Telia</td></tr>
        <tr class="hop-ok"><td>11</td><td class="mono">141.101.65.141 / 141.136.97.98 (+5)</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">88.7</td><td class="num">74.6</td><td class="num">62.0</td><td class="num">98.1</td><td class="num">12.4</td><td>CF AMS anycast</td></tr>
        <tr class="hop-ok"><td>12</td><td class="mono">104.26.15.26 / 198.41.240.9 (+2)</td><td class="num loss-ok">0.0%</td><td class="num">10</td><td class="num">110.7</td><td class="num">79.6</td><td class="num">64.2</td><td class="num">129.6</td><td class="num">22.2</td><td><strong class="bad">CF AMS edge ✗</strong></td></tr>
      </tbody>
    </table>
  </div>

  <!-- A / TTNet / Test 2 -->
  <div class="mtr-block">
    <div class="mtr-header">
      <span class="title">Site A &nbsp;·&nbsp; <span class="tt">TTNet</span> &nbsp;·&nbsp; Test 2</span>
      <span class="meta">2026-03-25 17:48:08 &nbsp;|&nbsp; <span class="tag tag-r">AMS</span> &nbsp;|&nbsp; 14 hop</span>
